coverage/
.nyc_output/

# Claude Code local-only settings (project settings.json IS committed; .local.json is not)
.claude/settings.local.json
.claude/*.local.md

# Worktrees created by /spawn-team — never commit these to the host repo
.claude/worktrees/

# Personal session memory and in-progress planning documents
memory/
plans/
