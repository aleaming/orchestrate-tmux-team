# Secrets — NEVER commit
.env
.env.local
.env.*.local
*.pem
*.key
credentials.json
secrets.json

# Dependencies
node_modules/
.pnpm-store/

# Build artifacts
dist/
build/
out/
*.tsbuildinfo

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
logs/

# OS / editor cruft
.DS_Store
Thumbs.db
*.swp
*.swo
.vscode/
.idea/

