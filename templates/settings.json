{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "_comment": "Project-scoped Claude Code settings template. Copy to .claude/settings.json and adjust paths if needed. Hooks reference scripts under ./hooks/.",

  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Read|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ./hooks/block-secrets.py"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash ./hooks/block-dangerous-commands.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash ./hooks/after-edit.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ./hooks/end-of-turn.sh"
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ./hooks/notify.sh"
          }
        ]
      }
    ]
  },

  "permissions": {
    "allow": [
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(ls:*)",
      "Bash(tmux ls:*)",
      "Bash(tmux list-sessions:*)"
    ],
    "deny": []
  }
}
