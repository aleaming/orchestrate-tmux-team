# orchestrate-tmux-team — environment template
# Copy to .env and fill in real values. .env is git-ignored.

# --- tmux session configuration ---
ORCHESTRATE_SESSION_NAME=team
ORCHESTRATE_DEFAULT_LAYOUT=tiled

# --- agent runtime ---
# Path to the agent binary or command to launch in each pane (e.g. "claude" or a wrapper script)
AGENT_COMMAND=claude
# Number of agent panes to spin up by default
AGENT_COUNT=3

# --- API keys (NEVER commit real values) ---
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME
# OPENAI_API_KEY=sk-REPLACE_ME

# --- logging ---
LOG_LEVEL=info
LOG_DIR=./logs
